# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Build / Distribution
build_tmp/
build_venv/
dist/

# PyInstaller（airtype.spec 已追蹤，不排除）
# build/ 目錄下的建置腳本已追蹤，但排除 PyInstaller 中間產物
build/__pycache__/
build/airtype/

# chatllm binaries (DLL / EXE / LIB)
chatllm/bin/*.dll
chatllm/bin/*.exe
chatllm/bin/*.lib
chatllm/bin/*.pem
chatllm/bindings/*.lib

# Models (large binary files)
models/vad/*.onnx
models/precomputed/*.npy

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Claude / Agent / Spectra tooling
.agent/
.claude/
.spectra/
openspec/.vector-search.db*

# Testing / Benchmarks
.pytest_cache/
.benchmarks/
htmlcov/
.coverage
.coverage.*

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Misc
# pip 在 cmd.exe 中執行 "pip install pkg>=x.y" 時，>= 的 > 被誤解為重定向，
# 產生 "x.y"、"=x.y" 等垃圾檔案
[0-9].[0-9]
[0-9].[0-9][0-9]
=[0-9].[0-9]*
